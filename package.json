{
  "name": "blazingmq-node",
  "version": "1.2.0",
  "description": "Unofficial pure-JavaScript Node.js SDK for BlazingMQ — Bloomberg's high-performance open-source message queue",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathPattern=protocol",
    "test:integration": "jest --runInBand --testPathPattern=integration",
    "test:coverage": "jest --runInBand --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run rebuild"
  },
  "keywords": [
    "blazingmq",
    "message-queue",
    "pubsub",
    "publish-subscribe",
    "messaging",
    "queue",
    "broker",
    "bloomberg"
  ],
  "author": "Rohan Doshi",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RohanDoshi21/blazingmq-sdk-node.git"
  },
  "bugs": {
    "url": "https://github.com/RohanDoshi21/blazingmq-sdk-node/issues"
  },
  "homepage": "https://github.com/RohanDoshi21/blazingmq-sdk-node#readme",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
