{
  "name": "blazingmq",
  "version": "1.0.0",
  "description": "Production-ready Node.js SDK for BlazingMQ — a high-performance, open-source message queue system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --runInBand",
    "test:integration": "jest --runInBand --testPathPattern=integration",
    "lint": "eslint src/ --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "blazingmq",
    "message-queue",
    "pubsub",
    "publish-subscribe",
    "messaging",
    "queue",
    "broker"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
